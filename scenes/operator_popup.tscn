[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/operator_popup.gd" id="1"]

[node name="OperatorPopup" type="Control"]
visible = false
script = ExtResource("1")

[node name="PanelContainer" type="PanelContainer" parent="."]
offset_right = 200.0
offset_bottom = 100.0

[node name="VBoxContainer" type="VBoxContainer" parent="PanelContainer"]
layout_mode = 2

[node name="Label" type="Label" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
text = "Choose operator"
horizontal_alignment = 1

[node name="HBoxContainer" type="HBoxContainer" parent="PanelContainer/VBoxContainer"]
layout_mode = 2

[node name="ButtonPlus" type="Button" parent="PanelContainer/VBoxContainer/HBoxContainer"]
layout_mode = 2
text = "+"

[node name="ButtonMinus" type="Button" parent="PanelContainer/VBoxContainer/HBoxContainer"]
layout_mode = 2
text = "−"

[node name="ButtonMul" type="Button" parent="PanelContainer/VBoxContainer/HBoxContainer"]
layout_mode = 2
text = "×"

[node name="ButtonDiv" type="Button" parent="PanelContainer/VBoxContainer/HBoxContainer"]
layout_mode = 2
text = "÷"

[connection signal="pressed" from="PanelContainer/VBoxContainer/HBoxContainer/ButtonPlus" to="." method="_on_button_pressed" binds=["+"]]
[connection signal="pressed" from="PanelContainer/VBoxContainer/HBoxContainer/ButtonMinus" to="." method="_on_button_pressed" binds=["-"]]
[connection signal="pressed" from="PanelContainer/VBoxContainer/HBoxContainer/ButtonMul" to="." method="_on_button_pressed" binds=["*"]]
[connection signal="pressed" from="PanelContainer/VBoxContainer/HBoxContainer/ButtonDiv" to="." method="_on_button_pressed" binds=["/"]]
